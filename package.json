{
  "name": "shadowrecon-ultimate",
  "productName": "ShadowRecon Ultimate",
  "version": "7.7.7",
  "description": "Complete penetration testing framework with 200+ tools, exploit database, network sniffer, and unlimited system access.",
  "main": "main.js",
  "author": "ShadowRecon Labs",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "pack": "electron-builder --dir",
    "clean": "rimraf dist/ reports/ logs/ tools/"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.0.1"
  },
  "build": {
    "appId": "com.shadowrecon.ultimate",
    "productName": "ShadowRecon Ultimate",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!reports/**",
      "!logs/**",
      "!tools/**",
      "!captures/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
