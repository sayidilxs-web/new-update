{
  "name": "shadowrecon-base-custom-ready",
  "productName": "ShadowRecon Base – Custom Ready",
  "version": "1.0.0",
  "description": "Defensive web configuration review desktop app with WebView, traffic timing log, integrated defensive checks, and report export.",
  "main": "main.js",
  "author": "ShadowRecon",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.shadowrecon.base.customready",
    "productName": "ShadowRecon Base – Custom Ready",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!reports/**",
      "!.git/**",
      "!.vscode/**"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
